# Local SDK build/publish output (make {nodejs,python,dotnet}_sdk) -
# only the pulumi package gen-sdk source under sdk/*/ is committed. These
# live below sdk/python/.gitignore etc., which get wiped and regenerated by
# codegen, so the patterns belong here instead.
